rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model designed for cross-device synchronization. 
     * Security is achieved through path-based authorization where all sensitive data is nested 
     * under a unique user identifier.
     *
     * DATA STRUCTURE
     * - /users/{userId}: Root profiles where the document ID matches the Firebase Auth UID.
     * - /users/{userId}/tasks/{taskId}: User-specific tasks nested under the owner's profile.
     *
     * KEY SECURITY DECISIONS
     * - Authorization Independence: The 'userId' is denormalized onto Task documents. This allows 
     *   rules to verify ownership by comparing the document data directly against the auth token 
     *   and the URL path without requiring expensive cross-document lookups (get() calls).
     * - Private Scoping: User listing is disabled globally to prevent enumeration of the user base.
     * - Structural Segregation: Tasks are strictly sub-resources of a User, ensuring that 
     *   queries are naturally scoped to the authenticated user's data tree.
     *
     * DENORMALIZATION FOR AUTHORIZATION
     * To ensure high performance and maintainable rules, the 'userId' field is required on all 
     * Task documents. This allows the 'isOwner' check to validate both the path and the 
     * internal document state simultaneously.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is made by an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user owns the existing document before allowing modification or deletion. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents. Users can only manage their own profile.
     * @path /users/{userId}
     * @allow (create) if auth.uid == 'user_123' and data.id == 'user_123'
     * @deny (list) always denied to prevent user enumeration.
     * @principle Enforces self-creation and strict ownership of profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for tasks belonging to a specific user.
       * @path /users/{userId}/tasks/{taskId}
       * @allow (list) if auth.uid == userId.
       * @deny (create) if the denormalized 'userId' field in the data does not match the path userId.
       * @principle Validates relational integrity by ensuring the internal 'userId' matches the owner path.
       */
      match /tasks/{taskId} {
        allow get, list: if isOwner(userId);
        
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId;
          
        allow update: if isExistingOwner(userId) 
          && request.resource.data.userId == resource.data.userId;
          
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}